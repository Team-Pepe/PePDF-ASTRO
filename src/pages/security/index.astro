---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar';
import Footer from '../../components/layout/Footer';
import ComingSoonPanel from '../../components/shared/ComingSoonPanel';
---

<Layout title="PePDF | Security" description="Security practices and trust documentation for PePDF.">
  <Navbar client:load />
  <main>
    <ComingSoonPanel
      client:load
      title="Security"
      subtitle="We are preparing a complete security overview with encryption and data handling standards."
      ctaHref="/protect"
      ctaLabel="Explore protect tools"
    />
  </main>
  <Footer client:visible />
</Layout>
