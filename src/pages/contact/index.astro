---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar';
import Footer from '../../components/layout/Footer';
import ComingSoonPanel from '../../components/shared/ComingSoonPanel';
---

<Layout title="PePDF | Contact" description="Contact PePDF support and product team.">
  <Navbar client:load />
  <main>
    <ComingSoonPanel
      client:load
      title="Contact"
      subtitle="A dedicated contact and support page is being prepared with direct channels."
      ctaHref="/help-center"
      ctaLabel="Open help center"
    />
  </main>
  <Footer client:visible />
</Layout>
